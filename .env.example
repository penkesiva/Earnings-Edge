# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Alpaca Pro (you have this)
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://data.alpaca.markets

# Financial Modeling Prep ($25/mo Starter)
FMP_API_KEY=

# Resend (free tier ok)
RESEND_API_KEY=
NOTIFY_EMAIL=

# Web Push (generate via: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@yourdomain.com

# LLM provider for narrative overhang classification (set ONE or both).
# Gemini is preferred when both keys are present.
# Without either key the system falls back to regex keyword matching.
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Cron security — required for HTTP GET /api/cron/* (Vercel Cron, curl, GitHub Actions).
# Not required for dashboard "Sync calendar" / "Run daily scan" buttons (server actions).
CRON_SECRET=

# Auth — set AUTH_ALLOWED_EMAILS to enable login gate (comma-separated, lowercase ok).
# Friends must use Google sign-in; only listed emails get in.
# Optional SITE_PASSWORD keeps legacy passphrase login for you.
# Optional: force OAuth redirect origin when Site URL in Supabase differs (e.g. production URL).
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
AUTH_ALLOWED_EMAILS=you@gmail.com,friend@gmail.com
SITE_PASSWORD=
